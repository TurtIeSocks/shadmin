{
  "name": "shadmin-core",
  "version": "0.1.0",
  "private": true,
  "description": "Headless, type-safe, UI-agnostic admin logic for shadmin. Currently re-exports ra-core; the in-house replacement lands here incrementally. No JSX, no shadcn deps.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --browser.headless"
  },
  "dependencies": {
    "ra-core": "^5.14.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=19"
  },
  "devDependencies": {
    "@types/node": "^22.19.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^3.2.4",
    "mock-socket": "^9.3.1",
    "playwright": "^1.57.0",
    "ra-data-fakerest": "^5.14.0",
    "typescript": "~5.7.2",
    "vitest": "^3.2.4"
  }
}
