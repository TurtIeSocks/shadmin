{
  "name": "GeoJsonInput",
  "props": [
    {
      "name": "attribution",
      "type": "string",
      "optional": true,
      "comment": ""
    },
    {
      "name": "collection",
      "type": "boolean",
      "optional": true,
      "comment": "When true, persists as a `GeometryCollection` of every shape on the\nmap. When false (default), keeps only the most recently drawn shape."
    },
    {
      "name": "defaultCenter",
      "type": "[number, number]",
      "optional": true,
      "comment": ""
    },
    {
      "name": "disabled",
      "type": "boolean",
      "optional": true,
      "comment": ""
    },
    {
      "name": "height",
      "type": "string | number",
      "optional": true,
      "comment": ""
    },
    {
      "name": "helperText",
      "type": "ReactNode",
      "optional": true,
      "comment": ""
    },
    {
      "name": "label",
      "type": "ReactNode",
      "optional": true,
      "comment": ""
    },
    {
      "name": "pathOptions",
      "type": "PathOptions",
      "optional": true,
      "comment": ""
    },
    {
      "name": "shapes",
      "type": "ShapeKind[]",
      "optional": true,
      "comment": "Which GeoJSON shape kinds the user can draw. Each maps to a Geoman\ndraw button; duplicates (e.g. Point + MultiPoint both → Marker) are\ndeduped."
    },
    {
      "name": "snapDistance",
      "type": "number",
      "optional": true,
      "comment": ""
    },
    {
      "name": "snappable",
      "type": "boolean",
      "optional": true,
      "comment": ""
    },
    {
      "name": "source",
      "type": "string",
      "optional": false,
      "comment": ""
    },
    {
      "name": "tileUrl",
      "type": "string",
      "optional": true,
      "comment": ""
    },
    {
      "name": "validate",
      "type": "(v: unknown) => string | undefined | (v: unknown) => string | undefined[]",
      "optional": true,
      "comment": ""
    },
    {
      "name": "zoom",
      "type": "number",
      "optional": true,
      "comment": ""
    }
  ]
}
