      "type": "GeomanShape[]",
      "optional": true,
      "comment": "Override the toolbar draw buttons. When omitted, derived from `shape`.\nUse when a single GeoJSON output type (e.g. Polygon) can be produced by\nmultiple draw modes (Polygon, Rectangle, Circle)."
