      "name": "aspectRatio",
      "type": "number",
      "optional": true,
      "comment": "Lock the stored bbox to width/height = ratio. The drawn rectangle is\nresized to match before persistence. Note: the displayed layer keeps the\nfreely-drawn extent until next hydration."
    },
