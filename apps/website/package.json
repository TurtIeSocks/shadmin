    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "react-shiki": "^0.7.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/postcss": "^4.3.0",
