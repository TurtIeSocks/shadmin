{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "registry:generate": {
      "outputs": ["registry.json"]
    },
    "registry:build": {
      "dependsOn": ["registry:generate"],
      "outputs": ["dist/r/**"]
    },
    "typecheck": {},
    "test": {},
    "check-coverage": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/packages/shadmin/src/**",
        "$TURBO_ROOT$/packages/shadmin/registry.json",
        "$TURBO_ROOT$/apps/demo/src/**"
      ]
    },
    "dev": { "cache": false, "persistent": true },
    "storybook": { "cache": false, "persistent": true }
  }
}
