{
  "name": "FeatureInput",
  "props": [
    {
      "name": "attribution",
      "type": "string",
      "optional": true,
      "comment": ""
    },
    {
      "name": "defaultCenter",
      "type": "[number, number]",
      "optional": true,
      "comment": ""
    },
    {
      "name": "disabled",
      "type": "boolean",
      "optional": true,
      "comment": ""
    },
    {
      "name": "geomanShapes",
      "type": "GeomanShape[]",
      "optional": true,
      "comment": "Override the toolbar draw buttons. When omitted, derived from `shape`.\nUse when a single GeoJSON output type (e.g. Polygon) can be produced by\nmultiple draw modes (Polygon, Rectangle, Circle)."
    },
    {
      "name": "height",
      "type": "string | number",
      "optional": true,
      "comment": ""
    },
    {
      "name": "helperText",
      "type": "ReactNode",
      "optional": true,
      "comment": ""
    },
    {
      "name": "label",
      "type": "ReactNode",
      "optional": true,
      "comment": ""
    },
    {
      "name": "pathOptions",
      "type": "PathOptions",
      "optional": true,
      "comment": ""
    },
    {
      "name": "shape",
      "type": "\"Point\" | \"MultiPoint\" | \"LineString\" | \"MultiLineString\" | \"Polygon\" | \"MultiPolygon\"",
      "optional": true,
      "comment": "Default geometry type when the user starts drawing. Defaults to `\"Polygon\"`."
    },
    {
      "name": "snapDistance",
      "type": "number",
      "optional": true,
      "comment": ""
    },
    {
      "name": "snappable",
      "type": "boolean",
      "optional": true,
      "comment": ""
    },
    {
      "name": "source",
      "type": "string",
      "optional": false,
      "comment": ""
    },
    {
      "name": "tileUrl",
      "type": "string",
      "optional": true,
      "comment": ""
    },
    {
      "name": "validate",
      "type": "(v: unknown) => string | undefined | (v: unknown) => string | undefined[]",
      "optional": true,
      "comment": ""
    },
    {
      "name": "zoom",
      "type": "number",
      "optional": true,
      "comment": ""
    }
  ]
}
